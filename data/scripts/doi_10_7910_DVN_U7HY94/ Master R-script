int_range <- function(x, min_levels = 5) { 
  
  int_range <- floor(min(x, na.rm = TRUE)):ceiling(max(x, na.rm = TRUE))
  
  if (length(int_range) < min_levels) {
    
    int_range <- floor(min(x*10, na.rm = TRUE)):ceiling(max(x*10, na.rm = TRUE)) / 10
    
  } 
  
  if (length(int_range) < min_levels) {
    
    int_range <- floor(min(x*100, na.rm = TRUE)):ceiling(max(x*100, na.rm = TRUE)) / 100
    
  }
  
  if (length(int_range) < min_levels) {
    
    int_range <- floor(min(x*1000, na.rm = TRUE)):ceiling(max(x*1000, na.rm = TRUE)) / 1000
    
  }
  
  return(int_range)
  
} 

