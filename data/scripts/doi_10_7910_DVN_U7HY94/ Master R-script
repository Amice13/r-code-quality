# input API KEY
api_inputs <- list(metobs = list(base_url = "https://dmigw.govcloud.dk/v2/metObs/collections/observation/items",
                                 api_key = NULL),
                   oceanobs = list(base_url = "https://dmigw.govcloud.dk/v2/oceanObs/collections/observation/items",
                                   api_key = NULL),
                   lightningdata = list(base_url = "https://dmigw.govcloud.dk/v2/lightningdata/collections/observation/items",
                                        api_key = NULL),
                   climatedata = list(base_url = "https://dmigw.govcloud.dk/v2/climateData/collections/stationValue/items",
                                      api_key = NULL),
                   climatedata_grid10 = list(base_url = "https://dmigw.govcloud.dk/v2/climateData/collections/10kmGridValue/items",
                                             api_key = NULL),
                   climatedata_grid20 = list(base_url = "https://dmigw.govcloud.dk/v2/climateData/collections/20kmGridValue/items",
                                             api_key = NULL),
                   climatedata_municipality = list(base_url = "https://dmigw.govcloud.dk/v2/climateData/collections/municipalityValue/items",
                                                   api_key = NULL)
)


get_weather <- function(from_ymd=NULL,
                        to_ymd=NULL,
                        parameter_id=NULL,
                        set_api=NULL,
                        station_id=NULL,
                        additional_params=NULL, 
                        limit=300000,
                        n_max=10e7,
                        base_url=NULL, 
                        api_key=NULL) {
  
  library(tidyverse)
  library(purrr)
  library(httr)
  library(lubridate)
  options(scipen=999)
  
  api_response_list <- list()
  
  # Api (inputs)
  
  if (!is.null(set_api)) {
    
    api <- set_api
    
  } else if (is.null(parameter_id)) {
    
    api <- "metobs"  
    
  } else if (parameter_id %in% c("temp_dry","temp_dew", "temp_mean_past1h","temp_max_past1h","temp_min_past1h","temp_max_past12h","temp_min_past12h","temp_grass","temp_grass_max_past1h","temp_grass_mean_past1h","temp_grass_min_past1h","temp_soil", "temp_soil_max_past1h","temp_soil_mean_past1h","temp_soil_min_past1h","humidity","humidity_past1h","pressure","pressure_at_sea","wind_dir","wind_dir_past1h","wind_speed","wind_speed_past1h","wind_gust_always_past1h", "wind_max","wind_min_past1h","wind_min","wind_max_per10min_past1h", "precip_past1h","precip_past10min","precip_past1min","precip_dur_past10min","precip_dur_past1h","snow_depth_man","snow_cover_man","visibility","visib_mean_last10min","cloud_cover","cloud_height","weather", "radia_glob","radia_glob_past1h","sun_last10min_glob","sun_last1h_glob","leav_hum_dur_past10min","leav_hum_dur_past1h")) {
    
    api <- "metobs"
    
  } else if (parameter_id %in% c("sea_reg", "sealev_dvr", "sealev_ln", "tw")) { 
    
    api <- "oceanobs" 
    
  } else { 
    
    stop(print("Error in parameter_id?")) 
    
  }
  
  # Api key
  if (!is.null(base_url) & !is.null(api_key)) { 
    base_url <- base_url 
    api_key <- api_key }
  
  else if (api == "climatedata") { 
    base_url <- api_inputs$climatedata$base_url 
    api_key <- api_inputs$climatedata$api_key
  }
  else if (api == "climatedata_grid10") { 
    base_url <- api_inputs$climatedata_grid10$base_url 
    api_key <- api_inputs$climatedata$api_key
  }
  else if (api == "climatedata_grid20") { 
    base_url <- api_inputs$climatedata_grid20$base_url 
    api_key <- api_inputs$climatedata$api_key
  }
  else if (api == "climatedata_municipality") { 
    base_url <- api_inputs$climatedata_municipality$base_url 
    api_key <- api_inputs$climatedata$api_key
  }
  else if (api == "metobs") { 
    base_url <- api_inputs$metobs$base_url 
    api_key <- api_inputs$metobs$api_key
  }
  else if (api == "oceanobs") { 
    base_url <- api_inputs$oceanobs$base_url
    api_key <- api_inputs$oceanobs$api_key
  }
  else if (api == "lightningdata") { 
    base_url <- api_inputs$lightningdata$base_url 
    api_key <- api_inputs$lightningdata$api_key
  }
  else { stop(print("Missing or wrong base_url or API key")) }
  
  # Date(s)
  # From date
  if (is.character(from_ymd) | is.Date(from_ymd)) {
    from <- ymd(from_ymd)
  } else {
    warning("Date parameter(s) unspecified (YYYY-MM-DD) - fetching today's date.")
    from <- today() 
  }
  
  # To date
  if (is.character(to_ymd) | is.Date(to_ymd)){
    to <- ymd(to_ymd)
  } else {
    to <- from
  }
  
  from_out <- paste0(from, "T00:00:00Z") # OBS! Time zone!! Z = UTC, +01:00 = Danish winter time, +02:00 = Danish summer time 
  
  to_out <- paste0(to, "T23:59:59Z") # OBS! Time zone!! Z = UTC, +01:00 = Danish winter time, +02:00 = Danish summer time 
  
  date_param <- paste0("datetime=", from_out, "/", to_out)
  
  # Offsets
  offsets <- seq(0, n_max, limit)
  
  # Warnings
  if (is.null(parameter_id)) { warning("Weather parameter unspecified - fetching all possible variables.") }
  
  if (is.null(station_id)) { warning("Weather station unspecified - fetching data from all stations.") }
  
  # Set parameters (loop on offsets)
  
  for (i in seq_along(offsets)){
    
    # Standard parameters
    params <- paste(
      c(
        if (!is.null(parameter_id)) { paste0("parameterId=", parameter_id) },
        if (!is.null(station_id)) { paste0("stationId=", station_id) },
        if (!is.null(additional_params)) { additional_params },
        date_param,
        paste0("limit=", limit), 
        paste0("offset=", offsets[[i]]), 
        paste0("api-key=", api_key)
      ), collapse = "&")
    
    # Print url
    url <- paste0(base_url, "?", params)
    print(url)
    
    # Get data
    resp <- safely(GET)(url)$result
    
    # Break loop if nothing is retrieved
    if (is.null(resp)) { break }
    
    # Get content from API and add to list
    cont <- content(resp)
    api_response_list[[i]] <- cont
    
    # Break loop if nothing is retrieved or less than 300000 observations are retrieved
    if (is.null(cont) | length(cont) < 300000) { break }
  }
  
  return(api_response_list)
}

