##########################################################################################

tic()

# Specify inputs and outputs
station_match_dataset <- here::here("Data", "Intermediate", "voters_match_precipitation.rds") 
weather_dataset <- here::here("Data", "DMI", "precipitation_climatedata_daily_20h.rds")
intermediate_path <- here::here("Data", "Intermediate", "voters_weather_precipitation_20h.rds")

# Weather data: Load only measurements (values) plus station and date
weather_values <- read_rds(weather_dataset) %>% 
  filter(validity == TRUE,
         station_country == "DNK") %>% 
  select(station_id, date, value)

# Load voters data and add weather values
voters_weather <- voters_complete %>%
  select(voter_id, date) %>% # Only variables that identify voter-elections
  # Merge to add three nearest weather stations
  left_join(
    read_rds(station_match_dataset), # (load data frames with match between voters and nearest weather stations)
    by = c("voter_id", "date")) %>% 
  
  # Merge to add weather value from nearest station
  left_join(weather_values,
            by = c("station_id_1" = "station_id", "date")) %>% 
  rename(station_value_1 = value) %>% # rename value 
  
  # Merge to add weather value from 2nd nearest station
  left_join(weather_values,
            by = c("station_id_2" = "station_id", "date")) %>% 
  rename(station_value_2 = value) %>%  # rename value
  
  # Merge to add weather value from 3rd nearest station
  left_join(weather_values,
            by = c("station_id_3" = "station_id", "date")) %>% 
  rename(station_value_3 = value) %>%  # rename value
  
  # Do triangulation (inverse distance weighting), i.e., weighted average of three nearest stations
  rowwise() %>% 
  mutate(precipitation_20h = sum((station_value_1 * (1 / station_dist_1^2)),
                                 (station_value_2 * (1 / station_dist_2^2)),
                                 (station_value_3 * (1 / station_dist_3^2)), 
                                 na.rm = TRUE) / 
           sum(1 / station_dist_1^2, 
               1 / station_dist_2^2, 
               1 / station_dist_3^2, 
               na.rm = TRUE)) %>%
  ungroup() %>% 
  # rename station vars
  rename_with(~ paste0(., "_precipitation"), .cols = contains("station"))

