# function to convert API data to DF
climatedata_to_df <- function(api_content){
  
  library(tidyverse)
  library(janitor)
  library(lubridate)
  
  api_content %>% 
    flatten() %>% 
    map(pluck, "features") %>% 
    #pluck("features") %>% 
    flatten() %>% 
    map(pluck, "properties") %>% 
    #pluck("properties") %>% 
    bind_rows() %>% 
    transmute(station_id = stationId,
              time_from = ymd_hms(from, tz = "UTC") %>% with_tz("CET"),
              time_to = ymd_hms(to, tz = "UTC") %>% with_tz("CET"),
              date = as_date(time_from),
              parameter_id = parameterId,
              value = value,
              time_calculated = floor_date(ymd_hms(calculatedAt, tz = "UTC") %>% with_tz("CET"), "days"),
              time_created = floor_date(ymd_hms(created, tz = "UTC") %>% with_tz("CET"), "days"),
              time_resolution = timeResolution,
              validity = validity) %>%
    distinct() %>% 
    remove_empty("cols") %>%
    print() 
}

