grid_sf <- locations_sf %>%
  st_make_grid(1000L, what = "polygons", square = FALSE, flat_topped = FALSE, crs = 25832) %>%
  st_sf() %>%
  mutate(grid_id = factor(row_number()))

# Compute summary statistics by grid cell
locations_in_grid <- locations_sf %>%
  # Join voter data with grid, so each voter (row) gets the right grid_id
  st_join(grid_sf, join = st_intersects, sparse = TRUE) %>%
  # Drop geometry, only grid_id is needed as id
  st_drop_geometry() %>%
  # Collapse the few instances with more than one match (keep first match and mark via n_grid_matches > 1)
  group_by(location_id) %>%
  summarise(grid_id = first(grid_id),
            n_grid_matches = n()) %>%
  ungroup()

