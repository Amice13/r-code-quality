age_in_days_as_years_and_days <- function(age_in_days){
  
  library(lubridate)
  
  age_as_duration <- duration(day = age_in_days)
  age_as_decimal_years <- as.numeric(age_as_duration, "years")
  age_as_floor_years <- age_as_decimal_years %/% 1
  age_as_days <- as.numeric(age_as_duration, "days")
  age_more_than_floor_years_as_duration <- ddays(age_as_days) - dyears(age_as_floor_years)
  age_more_than_floor_years_as_days <- as.numeric(age_more_than_floor_years_as_duration, "days") |> floor()
  
  pretty <- paste0(age_as_floor_years, " years and ", age_more_than_floor_years_as_days, " days")
  
  return(pretty)
  
} 

