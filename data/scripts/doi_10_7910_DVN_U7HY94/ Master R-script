## 2013 data
#######################################################################

rain <- here::here("Data", "DMI", "precipitation_climatedata_daily_20h.rds") |> 
  read_rds() |> 
  st_as_sf(coords = c("station_easting", "station_northing"), crs = 25832) |> 
  filter(date %in% elections,
         year(date) == 2013)

rain_stations <- rain |> 
  distinct(station_id, geometry) |> 
  mutate(row_id = row_number())

rain_stations_id <- rain_stations |> 
  st_drop_geometry()

rain_obs <- rain |> 
  st_drop_geometry() |> 
  select(station_id, value)

nn_result <- st_nn(
  grid_centroids,
  rain_stations,
  sparse = TRUE,
  k = 3,
  returnDist = TRUE,
)

nn_row <- nn_result |> 
  pluck("nn") |> 
  unlist() |> 
  matrix(ncol = 3, byrow = TRUE, dimnames = list(NULL, c("station_row_1","station_row_2","station_row_3"))) |> 
  as.data.frame()

nn_dist <- nn_result |> 
  pluck("dist") |> 
  unlist() |> 
  matrix(ncol = 3, byrow = TRUE, dimnames = list(NULL, c("station_dist_1","station_dist_2","station_dist_3"))) |> 
  as.data.frame()

nn_df <- bind_cols(nn_row, nn_dist) |> 
  mutate(grid_id = row_number()) |> 
  left_join(rain_stations_id, c("station_row_1" = "row_id")) |> 
  rename(station_id_1 = station_id) |> 
  left_join(rain_stations_id, c("station_row_2" = "row_id")) |> 
  rename(station_id_2 = station_id) |> 
  left_join(rain_stations_id, c("station_row_3" = "row_id")) |> 
  rename(station_id_3 = station_id) 

grid_obs <- grid |> 
  
  # match distances
  left_join(nn_df, "grid_id") |> 
  
  # Merge to add weather value from nearest station
  left_join(rename(rain_obs, station_value_1 = value), by = c("station_id_1" = "station_id")) |> 
  left_join(rename(rain_obs, station_value_2 = value), by = c("station_id_2" = "station_id")) |> 
  left_join(rename(rain_obs, station_value_3 = value), by = c("station_id_3" = "station_id")) |> 
  
  # Do triangulation (inverse distance weighting), i.e., weighted average of three nearest stations
  rowwise() |> 
  mutate(precipitation_20h = sum((station_value_1 * (1 / station_dist_1^2)),
                                 (station_value_2 * (1 / station_dist_2^2)),
                                 (station_value_3 * (1 / station_dist_3^2)), 
                                 na.rm = TRUE) / 
           sum(1 / station_dist_1^2, 
               1 / station_dist_2^2, 
               1 / station_dist_3^2, 
               na.rm = TRUE)) |> 
  ungroup() |> 
  st_intersection(dk)

