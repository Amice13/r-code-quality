# Do example triangulation (inverse distance weighting), i.e., weighted average of three nearest stations

tibble(voter_id = "John",
       station_value_1 = 5,
       station_value_2 = 10,
       station_value_3 = 0,
       station_dist_1 = 10000,
       station_dist_2 = 20000,
       station_dist_3 = 30000) |> 
  mutate(station_weight_1 = (1 / station_dist_1^2),
         station_weight_2 = (1 / station_dist_2^2),
         station_weight_3 = (1 / station_dist_3^2),
         station_weight_sum = station_weight_1 + station_weight_2 + station_weight_3,
         station_weight_1_p = round(station_weight_1 / station_weight_sum * 100, 2),
         station_weight_2_p = round(station_weight_2 / station_weight_sum * 100, 2),
         station_weight_3_p = round(station_weight_3 / station_weight_sum * 100, 2)) |> 
  rowwise() |>
  mutate(station_avg_simple = sum(station_value_1,
                                  station_value_2,
                                  station_value_3,
                                  na.rm = TRUE) / 3,
         station_avg_weighted = sum(station_value_1 * station_weight_1,
                                    station_value_2 * station_weight_2,
                                    station_value_3 * station_weight_3, 
                                    na.rm = TRUE) / 
           sum(station_weight_1, station_weight_2, station_weight_3, na.rm = TRUE)) |> 
  ungroup() |> 
  # Round
  mutate_at(vars(contains("station_avg")), ~ round(.x, 2)) |> 
  gather() 

