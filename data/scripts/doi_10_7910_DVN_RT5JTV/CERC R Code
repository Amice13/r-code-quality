##########################################################################################################
################################### Random Effects for Stacked Dataset ###################################
##########################################################################################################

# For these analyses, use the stacked data sets. The stacked data set puts all of the DISTANT coins into
# a single column (DISTANT), and the SELF and LOCAL cups together (EGO). It also adds a control variable
# called GAME (0  = Self Game) which controls for the differential effects of each game. Note that in  
# this model, participants are modeled as a random effect (i.e., a higher-order variable) because each   
# person has a repeated measure (2 games * 30 coins per game).

cerc <- #FILENAME
  
RAG.S.E <-glmer(cbind(DISTANT, EGO)~
               DIEPUN+LGDIEPUN+OMNI.BG+OMNI.LG+
               BGR1+LGR1+MBG+MLG+
               AGE.C+as.factor(SEX)+FORMALED+MMAT+CHILDREN+
               CORELSIM+INGREMO+CORELEMO+POLEVAL+
               as.factor(HONEST)+as.factor(TREATMENT)+as.factor(INGFIRST)+as.factor(GAME)+
               relevel(SITE, "Tyva Republic")+(1 | CERCID),
             data=cerc, family=binomial)
summary(RAG.S.E)
rag <- RAG.S.E
se <- sqrt(diag(vcov(rag)))
tab <- cbind(Est = fixef(rag), LL = fixef(rag) - 1.96 * se, UL = fixef(rag) + 1.96 * se)
exp(tab)
