##########################################################################################################
######################################## RAG1:  DISTANT vs. LOCAL ########################################
##########################################################################################################

# Note that the following have all of the key variables in the aforementioned paper. To replicate
# specific models, delete the appropriate variable names from the following script. 

# Note, too, that the Punishment-Knowledge aggregate variables are HIGHGOD.BG (for the Moralistic God) and 
# HIGHGOD.LG (for the Local God). They are not included in the full models below. The "gods' rewards" 
# variables have two versions. BGR1 and LGR1 include Coastal Vanuatu while BGR2 and LGR2 do not. See
# Supplementary section S2.3.2 for more information.

##############################################
# This is for the "Local Co-Religionist Game".
##############################################

cerc <- #FILENAME

RAG1.E <-glm(cbind(COREL, INGROUP)~
               DIEPUN+LGDIEPUN+OMNI.BG+OMNI.LG+
               BGR1+LGR1+MBG+MLG+
               AGE.C+as.factor(SEX)+FORMALED+MMAT+CHILDREN+
               CORELSIM+INGREMO+CORELEMO+POLEVAL+
               as.factor(HONEST)+as.factor(TREATMENT)+as.factor(INGFIRST)+
               relevel(SITE, "Tyva Republic"),
               data=cerc, family=binomial)
summary(RAG1.E)
rag <- RAG1.E
exp(cbind(OR = coef(rag), confint(rag)))  #both CIs using profiled log-likelihood (for logistic models and ORs)
logisticPseudoR2s(rag)
vif(rag)        # Variance Inflation Factor: VIF > 10 is a problem for multi-colinearity
1/vif(rag)      # Tolerance: < 0.1 is a serious problem, < 0.2 potential problem
mvif <- data.frame(vif(rag))
mean(mvif$GVIF)  # Mean VIF: If substantially > 1, then regression may be biased

