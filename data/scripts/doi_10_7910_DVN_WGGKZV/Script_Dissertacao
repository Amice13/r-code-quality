## QUAL O MELHOR MODELO?
# Teste entre efeitos fixos e aleatŚrios - teste de Hausman
# H0 : a diferenŹa entre os coeficientes nŗo Ä sistemćtica (efeitos aleatŚrios Ä melhor)
# H1 : a diferenŹa entre os coeficientes Ä sistemćtica (efeitos fixos Ä melhor) - P VALOR PROXIMO DE 0 (MENOR QUE 5%)
# phtest(efeitos_fixos,efeitos_aleatorios)
phtest(plm_within_Yields_2, plm_random_Yields_2) # efeito fixo (H1) Ä melhor que aleatorio
phtest(plm_within_Yields_sub_2, plm_random_Yields_sub_2) # efeito fixo (H1) Ä melhor que aleatorio
phtest(plm_within_Payout_2, plm_random_Payout_2) # efeito aleatorio Ä melhor (H0) que fixo
phtest(plm_within_Payout_sub_2, plm_random_Payout_sub_2) # efeito fixo (H1) Ä melhor que aleatorio

# Teste entre pooled e efeitos aleatŚrios (ramdon) 
# H0 : efeito do painel nŗo Ä significante (pooled Ä o melhor modelo)
# H1 : efeito do painel Ä significante (efeitos aleatŚrios Ä o melhor) - P VALOR PROXIMO DE 0 (MENOR QUE 5%)
# plmtest(pooled,type="bp") - "bp" for Breusch and Pagan (1980) - Teste de efeitos individuais e/ou temporais para modelos de painel Ä significativo
#plmtest(plm_pool_Yields) 
plmtest(plm_pool_Yields_2, type = "bp") # 
plmtest(plm_pool_Yields_sub_2, type = "bp") # H1 - efeito do painel Ä significante (efeitos aleatŚrios Ä o melhor)
plmtest(plm_pool_Payout_2, type = "bp") # 
plmtest(plm_pool_Payout_sub_2, type = "bp") # H1 - efeito do painel Ä significante (efeitos aleatŚrios Ä o melhor)

# Teste entre efeito pooled e fixo (within): Teste de Chow - efeitos individuais e/ou temporais com base na comparaŹŗo dos 2 modelos
# H0 : efeitos individuais nŗo sŗo significantes (pooled Ä o melhor modelo)
# H1 : efeitos dos indivÆduos sŗo significantes (efeitos fixos Ä o melhor) - P VALOR PROXIMO DE 0 (MENOR QUE 5%)
# pFtest(efeitos_fixos,pooled) - Teste de Chow
pFtest(plm_within_Yields_2, plm_pool_Yields_2) # efeito individual fixo (padrao) 
pFtest(plm_within_Yields_sub_2, plm_pool_Yields_sub_2) # efeito fixo (H1) Ä melhor que pooled? NA
pFtest(plm_within_Payout_2, plm_pool_Payout_2) # efeito fixo (H1) Ä melhor que pooled? NA
pFtest(plm_within_Payout_sub_2, plm_pool_Payout_sub_2) # efeito fixo (H1) Ä melhor que pooled? NA


