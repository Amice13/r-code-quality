# criando funcao para Winsorizacao das variaveis
winsorize1 <- function(x) {
  lim <- quantile(x, probs = c(0.005,0.995), na.rm = T)
  x[x<lim[1]] <- lim[1]
  x[x>lim[2]] <- lim[2]
  return(x)
}

winsorize5 <- function(x) {
  lim <- quantile(x, probs = c(0.025,0.975), na.rm = T)
  x[x<lim[1]] <- lim[1]
  x[x>lim[2]] <- lim[2]
  return(x)
}

winsorize10 <- function(x) {
  lim <- quantile(x, probs = c(0.05,0.95), na.rm = T)
  x[x<lim[1]] <- lim[1]
  x[x>lim[2]] <- lim[2]
  return(x)
}

