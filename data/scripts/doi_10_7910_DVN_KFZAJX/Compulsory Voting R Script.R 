datos <- Compulsory.Voting.Benelux_20.july.2022
colnames(datos)
str(datos)
summary(datos)

datos$Compulsory1 = factor(datos$Compulsory1,
                           level = c(0:2),
                           labels = c("Voluntary", "PCompulsory", "FCompulsory"))

