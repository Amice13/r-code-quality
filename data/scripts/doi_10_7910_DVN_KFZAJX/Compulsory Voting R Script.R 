EVT1outliers <- datos[, c("CodeCoO", "CoO", "Year", "SpecialRepresentation", "OverseasDistricts", "TypeElection", "CoR",
                  "EVT1", "lnMigrantStock", "Inperson", "Remote", "VotingMethod", "Compulsory1",  "Compulsory2", "Compulsory3", "Registration", "Ballotage", "Corona")] 
