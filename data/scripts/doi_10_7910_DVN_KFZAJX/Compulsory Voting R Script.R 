SEVT1 <- datos[, c("CodeCoO", "CoO", "Year", "SpecialRepresentation", "OverseasDistricts", "TypeElection", "CoR", "SEVT1", "lnSEVT1", "lnRegistered", "Inperson", "Remote", "VotingMethod", "Compulsory1",  "Compulsory2", "Compulsory3", "Registration", "Ballotage", "Corona")] 
