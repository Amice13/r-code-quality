EVT1outliers <- EVT1outliers[-c(3, 4, 201, 211, 212, 213), ]
EVT2outliers <- EVT2outliers[-c(3, 4, 201, 211, 212, 213), ]

EVT1 <- na.omit(EVT1)
EVT2 <- na.omit(EVT2)
