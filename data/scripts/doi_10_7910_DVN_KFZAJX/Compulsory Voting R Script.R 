######################################################################
###prep datasets for panel data regression
######################################################################

library(plm)

pdata1 <- pdata.frame(EVT1, index=c("CodeCoO", "CoR"))
pdata2 <- pdata.frame(EVT2, index=c("CodeCoO", "CoR"))
pdata3 <- pdata.frame(SEVT1, index=c("CodeCoO", "CoR"))
pdata4 <- pdata.frame(SEVT2, index=c("CodeCoO", "CoR"))
pdata5 <- pdata.frame(EVT1outliers, index=c("CodeCoO", "CoR"))
pdata6 <- pdata.frame(EVT2outliers, index=c("CodeCoO", "CoR"))

######################################################################
##### PLM models
######################################################################

#Model1

#pooled OLS estimator
pooling <- plm(EVT1 ~ Compulsory1+OverseasDistricts+Registration+Remote+lnMigrantStock+TypeElection+Corona, data=pdata1, model="pooling") 
summary(pooling)


#between estimator
between <- plm(EVT1 ~ Compulsory1+OverseasDistricts+Registration+Remote+lnMigrantStock+TypeElection+Corona, data=pdata1, model="between")
summary(between)

#first differences estimator
firstdiff <- plm(EVT1 ~ Compulsory1+OverseasDistricts+Registration+Remote+lnMigrantStock+TypeElection+Corona, data=pdata1, model="fd")
summary(firstdiff)

#fixed effects estimator
fixed <- plm(EVT1 ~ Compulsory1+OverseasDistricts+Registration+Remote+lnMigrantStock+TypeElection+Corona, data=pdata1, model="within")
summary(fixed)

#random effects estimator
random <- plm(EVT1 ~ Compulsory1+OverseasDistricts+Registration+Remote+lnMigrantStock+TypeElection+Corona, data=pdata1, model="random")
summary(random)

#LM test for random effects versus OLS
plmtest(pooling)
plmtest(pooling, effect="time")

#Hausman test for fixed versus random effects model
phtest(random, fixed)


sjPlot::tab_model(random) ###clearly random

