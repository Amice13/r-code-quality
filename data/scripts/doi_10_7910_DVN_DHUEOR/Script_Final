# criando funcao para Winsorizacao das variaveis ap?s exclus?o dos outliers 
# (itilizaremos winsoriza??o entre 1% e 99%)
winsorize1 <- function(x) {
  lim <- quantile(x, probs = c(0.005,0.995), na.rm = T)
  x[x<lim[1]] <- lim[1]
  x[x>lim[2]] <- lim[2]
  return(x)
}

